<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="1381.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.pwr.ite.dynak.app.AppController">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="500.0" spacing="20.0">
            <children>
            <GridPane hgap="10.0" prefHeight="250.0" prefWidth="500.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <TextField fx:id="usernameTextField" prefHeight="25.0" prefWidth="124.0" promptText="Username" text="SampleUserName" />
                  <TextField fx:id="ipTextField" promptText="IP Address" text="127.0.0.1" GridPane.rowIndex="1" />
                  <TextField fx:id="portTextField" promptText="Port" text="9999" GridPane.rowIndex="2" />
                  <Button fx:id="connectButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="250.0" text="Connect" GridPane.rowIndex="3" />
                  <Button fx:id="disconnectButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="250.0" text="Disconnect" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Button fx:id="sendAttachmentButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="240.0" text="Send attachment" GridPane.columnIndex="1" />
                  <Button fx:id="downloadAttachmentButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="240.0" text="Download selected attachment" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button fx:id="createServerButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="240.0" text="Create server" GridPane.rowIndex="4" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets left="10.0" right="10.0" />
               </padding>
            </GridPane>
                <TextArea fx:id="logTextArea" editable="false" prefHeight="360.0" prefWidth="300.0" />
            </children>
            <padding>
                <Insets top="20.0" />
            </padding>
        </VBox>
        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="380.0">
            <children>
                <Label text="Attachments:">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            <TableView fx:id="attachmentsTable" prefHeight="625.0" prefWidth="300.0">
              <columns>
                <TableColumn fx:id="timeStampColumn" prefWidth="135.0" text="Time stamp:" />
                <TableColumn fx:id="fileNameColumn" prefWidth="244.0" text="File name:" />
              </columns>
            </TableView>
            </children></VBox>
        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="500.0">
