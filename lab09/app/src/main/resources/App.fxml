            <Button fx:id="domParseButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="130.0" text="Parse with DOM" />
            <Button fx:id="saxParseButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="130.0" text="Parse with SaX" />
