                    </font>
                </Label>
            <TextArea fx:id="chatTextArea" editable="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="500.0" />
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="chatMessageTextField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="70.0" prefWidth="435.0" />
                  <Button fx:id="sendMessageButton" mnemonicParsing="false" prefHeight="70.0" prefWidth="70.0" text="Send" />
               </children>
            </HBox>
            </children></VBox>
    </children>
